TELEGRAM_BOT_TOKEN=isi_token_bot_telegram_kamu

# Pilih provider LLM: groq (gratis), openrouter, atau agentrouter
# PENTING: tulis huruf kecil semua, tanpa spasi.
LLM_PROVIDER=groq

# --- Groq (jika LLM_PROVIDER=groq) ---
GROQ_API_KEY=isi_api_key_groq_kamu
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- OpenRouter (jika LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Kosongkan OPENROUTER_VISION_MODEL untuk pakai model yang sama.
OPENROUTER_VISION_MODEL=

# --- Agentrouter (jika LLM_PROVIDER=agentrouter) ---
# Nama model TANPA prefix dan pakai strip, contoh: claude-opus-4-8 (BUKAN anthropic/claude-opus-4.8)
# Base URL WAJIB lengkap sampai /v1/chat/completions
AGENTROUTER_API_KEY=
AGENTROUTER_BASE_URL=https://agentrouter.org/v1/chat/completions
AGENTROUTER_MODEL=claude-opus-4-8

BOT_NAME=Keen Telegram Agent
ADMIN_USER_ID=isi_user_id_telegram_kamu
DATABASE_PATH=data/memory.db
MAX_HISTORY_MESSAGES=10
BIRDEYE_API_KEY=
GMGN_COOKIE=
GMGN_USER_AGENT=
